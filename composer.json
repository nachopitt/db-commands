{
    "name": "nachopitt/db-commands",
    "description": "Artisan commands for managing databases.",
    "type": "library",
    "homepage": "https://github.com/nachopitt/db-commands",
    "keywords": ["database","sql","mysql","laravel","schema","create","drop","import","export"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0|^13.0",
        "symfony/process": "^7.0|^8.0"
    },
    "autoload": {
        "psr-4": {
            "Nachopitt\\Database\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nachopitt\\Database\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nachopitt\\Database\\ConsoleSupportServiceProvider"
            ]
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "mockery/mockery": "^1.6",
        "shipmonk/composer-dependency-analyser": "^1.8",
        "laravel/pint": "^1.13"
    },
    "scripts": {
        "test": "vendor/bin/phpunit --colors=always --testdox",
        "analyse-deps": "vendor/bin/composer-dependency-analyser",
        "lint": "vendor/bin/pint --test",
        "format": "vendor/bin/pint"
    }
}
